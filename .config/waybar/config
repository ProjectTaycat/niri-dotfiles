{
  "layer": "top",
  "position": "top",
  "spacing": 0,

  // Order of Modules
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-right": ["tray", "pulseaudio", "backlight", "battery", "clock", "idle_inhibitor", "power-profiles-daemon"],

  // Modules Configuration
  // Left Side Modules
  "niri/workspaces": {
    "format": "{value}",
  },
  "niri/window": {
    "format": "{}",
  },

  // Right Side Modules
  "tray": {
    "spacing": 10
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
    "format-bluetooth-muted": "MUTED ΎΑο {icon}ΎΛΦ {format_source}",
    "format-muted": "MUTED ΎΑο {format_source}",
    "format-source": "{volume}% ΎΕ░",
    "format-source-muted": "ΎΕ▒",
    "on-click": "pavucontrol",
    "format-icons": {
      "headphone": " ΎΑξ ",
      "hands-free": " ΎΨΡ ",
      "headset": " ΎΨΡ ",
      "phone": " ΎΓΧ ",
      "portable": " ΎΓΧ ",
      "car": " ΎΗ╣ ",
      "default": [" ΎΑο ", " ΎΑπ ", " ΎΑρ "]
    }
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [" ΌΟΞ", " ΌΠΥ", " ΌΠΣ", " ΌΠΠ", " ΌΠΟ", " ΌΠΞ", " ΌΠΛ", " ΌΠΙ", " ΌΟδ"]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": [" ΎΚΕ", " ΎΚΔ", " ΎΚΓ", " ΎΚΒ", " ΎΚΑ"]
  },
  "clock": {
    "format": "{:%G-%m-%d %H:%M}",
    "tooltip": true,
    "tooltip-format": "{calendar}",
    "timezone": "America/Chicago",
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░"
    }
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    },
  },
  "custom/notification": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γι",
      "dnd-none": "≤░ςΥ",
      "inhibited-notification": "≤░Γδ",
      "inhibited-none": "≤░ςΣ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░ςΣ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  }
}
