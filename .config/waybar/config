{
  "layer": "top",
  "position": "top",
  "spacing": 0,

  // Order of Modules
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-right": ["tray", "pulseaudio", "backlight", "battery", "clock", "idle_inhibitor", "power-profiles-daemon"],

  // Modules Configuration
  // Left Side Modules
  "niri/workspaces": {
    "format": "{value}",
  },
  "niri/window": {
    "format": "{}",
  },

  // Right Side Modules
  "tray": {
    "spacing": 10
  },
  "pulseaudio": {
    "format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
    "format-bluetooth-muted": "MUTED яАж {icon}яКФ {format_source}",
    "format-muted": "MUTED яАж {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "on-click": "pavucontrol",
    "format-icons": {
      "headphone": " яАе ",
      "hands-free": " яЦР ",
      "headset": " яЦР ",
      "phone": " яВХ ",
      "portable": " яВХ ",
      "car": " яЖ╣ ",
      "default": [" яАж ", " яАз ", " яАи "]
    }
  },
  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [" юОН", " юПУ", " юПС", " юПП", " юПО", " юПН", " юПК", " юПИ", " юОЫ"]
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-icons": [" яЙД", " яЙГ", " яЙВ", " яЙБ", " яЙА"]
  },
  "clock": {
    "format": "{:%G-%m-%d %H:%M}",
    "tooltip": true,
    "tooltip-format": "{calendar}",
    "timezone": "America/Chicago",
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "яГз",
      "performance": "яГз",
      "balanced": "яЙО",
      "power-saver": "яБм"
    },
  },
}
