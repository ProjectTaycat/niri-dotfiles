{
  "layer": "top",
  "position": "top",
  "spacing": 0,

  // Order of Modules
  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-right": ["tray", "pulseaudio", "backlight", "battery", "clock", "idle_inhibitor", "power-profiles-daemon"],

  // Modules Configuration
  // Left Side Modules
  "niri/workspaces": {
    "format": "{value}",
  },
  "niri/window": {
    "format": "{}",
  },

  // Right Side Modules
  "tray": {
    "spacing": 10,
  },
  "pulseaudio": {
    "format": "{icon} {volume}% {format_source}",
    "format-muted": "{icon} MUTED {format_source}",
    "format-bluetooth": "{icon}ΎΛΦ {volume}% {format_source}",
    "format-bluetooth-muted": "ΎΑο {icon}ΎΛΦ MUTED {format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒ MUTED",
    "on-click": "pavucontrol",
    "format-icons": {
      "headphone": "≤░ΜΜ",
      "headphone-muted": "≤░θΟ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
      "default-muted": "Ό╗ρ",
    }
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "tooltip-format": "Brightness: {percent}%",
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon} {capacity}%",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "tooltip-format": "Battery: {capacity}%\n{timeTo}",
  },
  "clock": {
    "format": "ΎΑΩ {:%G-%m-%d %H:%M}",
    "tooltip": true,
    "timezone": "America/Chicago",
    "tooltip-format": "<span font='GoogleSansCode Nerd Font Mono Medium'>{calendar}</span>",
    "calendar": {
      "on-scroll": 1,
      "mode-mon-col": 3,
      "format": {
        "months": "<b>{}</b>",
        "weekdays": "<span color='#89b4fa'><b>{}</b></span>",
        "today": "<span color='#cba6f7'><b>{}</b></span>",
      }
    },
    "actions": {
      "on-click": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    }
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΒχ",
      "deactivated": "ΎΒ░",
    },
    "tooltip-format-activated": "Idle inhibitor: {status}",
    "tooltip-format-deactivated": "Idle inhibitor: {status}",
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΔπ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ",
    },
  },
  "custom/notification": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "≤▒Ζτ",
      "none": "≤░Γε",
      "dnd-notification": "≤░Γι",
      "dnd-none": "≤░ςΥ",
      "inhibited-notification": "≤░Γδ",
      "inhibited-none": "≤░ςΣ",
      "dnd-inhibited-notification": "≤░Γδ",
      "dnd-inhibited-none": "≤░ςΣ",
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  }
}
